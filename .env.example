# Google OAuth (create at https://console.cloud.google.com/)
# App type: Web Application
# Authorized redirect URI: http://localhost:8000/api/auth/callback
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Anthropic Claude API (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# App config (optional overrides)
POLL_INTERVAL_HOURS=6
DATABASE_URL=sqlite:///./data/school_monitor.db

# Required for local HTTP OAuth redirect (not production-safe)
OAUTHLIB_INSECURE_TRANSPORT=1
